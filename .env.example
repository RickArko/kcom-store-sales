# Default variables for make targets.
# Copy to .env and edit to set your preferred defaults.
# Command-line arguments override these, which override the Makefile defaults.

# uv project virtual environment path (Makefile exports this as UV_PROJECT_ENVIRONMENT)
UV_PROJECT_ENVIRONMENT=.venv

# Default config for `make train`
CONFIG=config/baseline.yaml

# Default run name suffix (timestamp is prepended automatically)
RUN_NAME=benchmark

# Submission file and message for `make submit`
SUBMISSION_FILE=outputs/submissions/submission.csv
SUBMISSION_MSG=baseline: LightGBM with lag/rolling features
